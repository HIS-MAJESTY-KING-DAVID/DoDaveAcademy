  propositionId Int          @map("proposition_id")
  proposition   Proposition? @relation("Answer_propositionId", fields: [propositionId], references: [id])
  createdAt     DateTime     @map("created_at")

  @@index([studentId])
  @@index([propositionId])
  @@map("answer")
}

model ResetPasswordRequest {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
